# Copy to ".env" and fill in. The .env file is git-ignored.

# --- LLM (any OpenAI-compatible endpoint) used for RAG answers & extraction ---
# A Purdue GenAI key, an OpenAI key, a local GPT4All/Ollama server, etc.
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://genai.rcac.purdue.edu/api
LLM_MODEL=llama4:latest

# --- OpenAlex (no key required; an email joins the faster "polite pool") ---
OPENALEX_MAILTO=you@example.com

# --- Patents (optional), tried in priority order ---
# 1) USPTO Open Data Portal API key — live search, any topic (recommended).
#    Free key: https://data.uspto.gov/apis/getting-started
#    (needs a MyUSPTO account + ID.me identity verification).
USPTO_ODP_API_KEY=
# 2) Or a downloaded bulk dataset (keyless, offline). Grab g_patent.tsv from
#    https://patentsview.org/download/ and point this at the file.
PATENTSVIEW_BULK_TSV=
# If neither is set, a small bundled CRISPR sample is used so linkage still runs.

# --- Pipeline knobs (optional) ---
# DATA_DIR=./data
# CHROMA_PATH=./chroma_store
# INGEST_WORKERS=8
# TOP_K=5
