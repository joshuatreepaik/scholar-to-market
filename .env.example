# Copy to ".env" and fill in. The .env file is git-ignored.

# --- LLM (any OpenAI-compatible endpoint) used for RAG answers & extraction ---
# A Purdue GenAI key, an OpenAI key, a local GPT4All/Ollama server, etc.
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://genai.rcac.purdue.edu/api
LLM_MODEL=llama4:latest

# --- OpenAlex (no key required; an email joins the faster "polite pool") ---
OPENALEX_MAILTO=you@example.com

# --- Patents (optional): downloaded bulk dataset (no key) ---
# The legacy PatentsView Search API is being retired during USPTO's Open Data
# Portal (ODP) transition. Patent *bulk datasets* stay freely downloadable with
# no key. Download g_patent.tsv from https://patentsview.org/download/ (or the
# ODP Bulk Datasets API) and point this at the file to match patents to your
# topic. If unset, the pipeline uses the bundled CRISPR sample.
PATENTSVIEW_BULK_TSV=

# --- Pipeline knobs (optional) ---
# DATA_DIR=./data
# CHROMA_PATH=./chroma_store
# INGEST_WORKERS=8
# TOP_K=5
